# ===========================================
# React + Vite Frontend .gitignore
# ===========================================

# Node modules
node_modules/

# Vite build output
dist/
build/

# Local environment files
.env
.env.local
.env.development
.env.production

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Editor folders
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS-generated files
.DS_Store
Thumbs.db

# Temporary
tmp/
temp/
*.tmp

# Lock files (optional, but recommended to ignore for frontend teams)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Cache folders
.cache/
.vite/
.eslintcache

# Optional Tailwind JIT cache
.tailwind/

# Generated files
*.tsbuildinfo

# Images copied into public (optional)
public/uploads/
public/temp/

# Storybook (if present)
storybook-static/

# Testing coverage
coverage/
